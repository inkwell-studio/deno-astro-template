---
import { getCollection } from 'astro:content';
import { DocsCollection } from '@source/content.config';

import BaseLayout from '@layouts/base-layout.astro';

export async function getStaticPaths(): Promise<Array<{ params: { id: string } }>> {
    return (await getCollection('docs') as DocsCollection)
        .map((doc) => ({ params: { id: doc.id } }));
}

const { id } = Astro.params;

const doc = (await getCollection('docs') as DocsCollection)
    .find((doc) => doc.id === id);
---
<BaseLayout>
    <div class="flex flex-col justify-center items-center h-[70vh] gap-14">
        <div class="text-center py-16 px-32 border border-stone-400 rounded">
            <h2 class="text-lg font-bold mb-4">{doc?.data.title}</h2>
            <p>{doc?.data.text}</p>
        </div>
        <a
            href="/"
            class="text-5xl text-stone-500 hover:text-stone-950 dark:text-slate-500 dark:hover:text-slate-300 font-bold transition-colors"
        >home</a>
    </div>
</BaseLayout>
